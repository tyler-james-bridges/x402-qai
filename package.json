{
  "name": "x402-qai",
  "version": "0.3.0",
  "description": "Test x402 endpoints before your users do.",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "x402-qai": "dist/src/cli.js"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "dist/server/**/*.js",
    "dist/server/**/*.d.ts",
    "!dist/**/__tests__",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:server": "tsc",
    "start:server": "node dist/server/index.js",
    "dev:server": "node --import tsx server/index.ts",
    "lint": "eslint src/ server/",
    "format:check": "prettier --check 'src/**/*.ts' 'server/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'server/**/*.ts'",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest",
    "prepublishOnly": "npm run lint && npm run format:check && npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyler-james-bridges/x402-qai.git"
  },
  "bugs": {
    "url": "https://github.com/tyler-james-bridges/x402-qai/issues"
  },
  "homepage": "https://github.com/tyler-james-bridges/x402-qai#readme",
  "keywords": [
    "x402",
    "payments",
    "compliance",
    "scanner",
    "validator"
  ],
  "author": "Tyler James-Bridges",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@x402/core": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "@x402/hono": "^2.10.0",
    "commander": "^14.0.3",
    "hono": "^4.12.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
