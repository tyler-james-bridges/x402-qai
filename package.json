{
  "name": "x402-qai",
  "version": "0.1.0",
  "description": "Test x402 endpoints before your users do.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "x402-qai": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "format:check": "prettier --check 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest",
    "prepublishOnly": "npm run lint && npm run format:check && npm test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyler-james-bridges/x402-qai.git"
  },
  "bugs": {
    "url": "https://github.com/tyler-james-bridges/x402-qai/issues"
  },
  "homepage": "https://github.com/tyler-james-bridges/x402-qai#readme",
  "keywords": [
    "x402",
    "payments",
    "compliance",
    "scanner",
    "validator"
  ],
  "author": "Tyler James-Bridges",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "commander": "^14.0.3",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3",
    "zod": "^4.3.6"
  }
}
